# Azure AI Foundry project endpoint (for model inference)
AZURE_AI_PROJECT_ENDPOINT="https://<resource>.services.ai.azure.com/api/projects/<project>"

# Default model deployment name. Overrides the per-agent default in config.py.
# Works via pydantic-settings: maps to agent_deployment_name field in agent configs.
AGENT_DEPLOYMENT_NAME="gpt-4o"

# Environment (dev | qa | prod)
ENVIRONMENT="dev"

# Single agent to serve in hosted mode (app.py / docker-compose).
# Must be a registered agent name: code-helper, doc-assistant, or custom.
AGENT_NAME="code-helper"

# Azure AI Search (optional — pick ONE approach to enable RAG grounding)
#
# Option A: Explicit endpoint + index name
# AZURE_AI_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# AZURE_AI_SEARCH_INDEX_NAME=<index-name>
#
# Option B: Foundry knowledge base name (resolves endpoint + index automatically)
# AZURE_AI_SEARCH_KNOWLEDGE_BASE=<knowledge-base-name>
#
# For local dev, `az login` is sufficient via DefaultAzureCredential.
# For Container Apps, assign "Search Index Data Reader" to the managed identity.

# MCP Servers (optional — JSON list of MCP server configurations)
# Supported transports: stdio, http, websocket
# All agents automatically connect to these MCP servers as tools.
#
# Example: GitHub MCP server (stdio)
# MCP_SERVERS='[{"name":"github","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_PERSONAL_ACCESS_TOKEN":"ghp_..."}}]'
#
# Example: Azure MCP server (stdio — uses your az login credentials)
# MCP_SERVERS='[{"name":"azure","transport":"stdio","command":"npx","args":["-y","@azure/mcp@latest","server","start"]}]'
#
# Example: Remote HTTP MCP server
# MCP_SERVERS='[{"name":"web-api","transport":"http","url":"https://api.example.com/mcp"}]'
#
# Combine multiple servers in one JSON array:
# MCP_SERVERS='[{"name":"azure","transport":"stdio","command":"npx","args":["-y","@azure/mcp@latest","server","start"]},{"name":"github","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_PERSONAL_ACCESS_TOKEN":"ghp_..."}}]'

# Service principal credentials (optional — for non-interactive auth / containers)
# For local dev, `az login` is sufficient via DefaultAzureCredential.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Azure authority host (optional — for sovereign / government clouds).
# Omit or leave blank for commercial cloud (default: https://login.microsoftonline.com).
# US Government:    https://login.microsoftonline.us
# China (21Vianet): https://login.chinacloudapi.cn
# AZURE_AUTHORITY_HOST=https://login.microsoftonline.us
