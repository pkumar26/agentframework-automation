# Azure AI Foundry project endpoint (for model inference)
AZURE_AI_PROJECT_ENDPOINT="https://<resource>.services.ai.azure.com/api/projects/<project>"

# Default model deployment name (override per-agent in config.py)
AGENT_DEPLOYMENT_NAME="gpt-4o"

# Environment (dev | qa | prod)
ENVIRONMENT="dev"

# Agent to run in hosted mode (app.py / docker-compose)
AGENT_NAME="code-helper"

# Service principal credentials (optional — for non-interactive auth / containers)
# For local dev, `az login` is sufficient via DefaultAzureCredential.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
